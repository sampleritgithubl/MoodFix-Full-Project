<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Left Eye White -->
    <item
        android:width="40dp"
        android:height="28dp"
        android:left="20dp"
        android:top="20dp">
        <shape android:shape="oval">
            <solid android:color="@color/white" />
        </shape>
    </item>
    <!-- Left Pupil -->
    <item
        android:width="20dp"
        android:height="20dp"
        android:left="30dp"
        android:top="24dp">
        <shape android:shape="oval">
            <solid android:color="@color/text_black" />
        </shape>
    </item>
    <!-- Right Eye White -->
    <item
        android:width="40dp"
        android:height="28dp"
        android:right="20dp"
        android:top="20dp">
        <shape android:shape="oval">
            <solid android:color="@color/white" />
        </shape>
    </item>
    <!-- Right Pupil -->
    <item
        android:width="20dp"
        android:height="20dp"
        android:right="30dp"
        android:top="24dp">
        <shape android:shape="oval">
            <solid android:color="@color/text_black" />
        </shape>
    </item>
</layer-list>
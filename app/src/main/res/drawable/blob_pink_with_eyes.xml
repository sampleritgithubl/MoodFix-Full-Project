<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/primary_pink" />
            <size android:height="400dp" android:width="400dp" />
        </shape>
    </item>
    <!-- Left Eye White -->
    <item android:width="60dp" android:height="40dp" android:left="100dp" android:top="150dp">
        <shape android:shape="oval">
            <solid android:color="@color/white" />
        </shape>
    </item>
    <!-- Left Pupil -->
    <item android:width="30dp" android:height="30dp" android:left="120dp" android:top="155dp">
        <shape android:shape="oval">
            <solid android:color="@color/text_black" />
        </shape>
    </item>
    <!-- Right Eye White -->
    <item android:width="60dp" android:height="40dp" android:right="100dp" android:top="150dp">
        <shape android:shape="oval">
            <solid android:color="@color/white" />
        </shape>
    </item>
    <!-- Right Pupil -->
    <item android:width="30dp" android:height="30dp" android:right="120dp" android:top="155dp">
        <shape android:shape="oval">
            <solid android:color="@color/text_black" />
        </shape>
    </item>
</layer-list>
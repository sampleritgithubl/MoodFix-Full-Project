<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_warm">

    <TextView
        android:id="@+id/heading"
        style="@style/HeadingText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="64dp"
        android:text="@string/reflect_on_goal"
        android:textSize="40sp"
        android:lineSpacingMultiplier="0.9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvPrompt"
        style="@style/BodyText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/what_changed"
        android:textSize="20sp"
        app:layout_constraintStart_toStartOf="@+id/heading"
        app:layout_constraintTop_toBottomOf="@+id/heading" />

    <EditText
        android:id="@+id/etReflectionText"
        style="@style/PillInput"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        android:gravity="top"
        android:hint="@string/hint_reflection"
        android:importantForAutofill="no"
        android:inputType="textMultiLine|textCapSentences"
        android:padding="24dp"
        app:layout_constraintBottom_toTopOf="@+id/tvMoodPrompt"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvPrompt" />

    <TextView
        android:id="@+id/tvMoodPrompt"
        style="@style/BodyText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="@string/mood_prompt"
        android:textSize="18sp"
        app:layout_constraintBottom_toTopOf="@+id/moodScrollView"
        app:layout_constraintStart_toStartOf="@+id/heading" />

    <HorizontalScrollView
        android:id="@+id/moodScrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:clipToPadding="false"
        android:paddingHorizontal="32dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@+id/btnSaveReflection">

        <RadioGroup
            android:id="@+id/rgMoods"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbRelieved"
                style="@style/SecondaryPillButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:button="@null"
                android:paddingHorizontal="20dp"
                android:text="@string/mood_relieved" />

            <RadioButton
                android:id="@+id/rbFrustrated"
                style="@style/SecondaryPillButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:button="@null"
                android:paddingHorizontal="20dp"
                android:text="@string/mood_frustrated" />

            <RadioButton
                android:id="@+id/rbInspired"
                style="@style/SecondaryPillButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:button="@null"
                android:paddingHorizontal="20dp"
                android:text="@string/mood_inspired" />

            <RadioButton
                android:id="@+id/rbStuck"
                style="@style/SecondaryPillButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:button="@null"
                android:paddingHorizontal="20dp"
                android:text="@string/mood_stuck" />

            <RadioButton
                android:id="@+id/rbProud"
                style="@style/SecondaryPillButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:button="@null"
                android:paddingHorizontal="20dp"
                android:text="@string/mood_proud" />

        </RadioGroup>
    </HorizontalScrollView>

    <Button
        android:id="@+id/btnSaveReflection"
        style="@style/PillButton"
        android:layout_width="wrap_content"
        android:layout_height="64dp"
        android:layout_marginBottom="48dp"
        android:paddingHorizontal="64dp"
        android:text="@string/save_reflection"
        android:textSize="18sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>